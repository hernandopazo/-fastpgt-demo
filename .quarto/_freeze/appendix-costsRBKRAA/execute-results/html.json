88661971830982,64.283263888888882],[null,413.30833333333322,354.26428571428562,309.98124999999993,275.53888888888883,247.98499999999996,225.44090909090903,206.65416666666661,190.75769230769225,177.13214285714281,165.3233333333333,154.99062499999997,145.87352941176468,137.76944444444442,130.51842105263154,123.99249999999998,118.08809523809521,112.72045454545452,107.81956521739129,103.32708333333331,99.193999999999974,95.378846153846126,91.846296296296273,88.566071428571405,85.512068965517216,82.661666666666648,79.995161290322557,77.495312499999983,75.146969696969677,72.936764705882339,70.852857142857133,68.884722222222209,67.022972972972951,65.259210526315769,63.585897435897422,61.996249999999989,60.484146341463401,59.044047619047603,57.670930232558128,56.360227272727258,55.107777777777763,53.909782608695643,52.762765957446796,51.663541666666653,83.635204081632637,81.962499999999977,80.35539215686272,78.810096153846132,77.323113207547152,75.891203703703681,74.511363636363626,73.180803571428555,71.896929824561383,70.657327586206875,69.459745762711847,68.302083333333314,67.182377049180317,66.098790322580626,65.049603174603163,64.033203124999986,63.048076923076906,62.092803030303017,61.166044776119392,60.266544117647044,59.39311594202897,58.544642857142847,57.720070422535201,56.918402777777764]],\"reversescale\":true,\"cmin\":40,\"cmax\":100,\"type\":\"surface\",\"frame\":null}],\"highlight\":{\"on\":\"plotly_click\",\"persistent\":false,\"dynamic\":false,\"selectize\":false,\"opacityDim\":0.20000000000000001,\"selected\":{\"opacity\":1},\"debounce\":0},\"shinyEvents\":[\"plotly_hover\",\"plotly_click\",\"plotly_selected\",\"plotly_relayout\",\"plotly_brushed\",\"plotly_brushing\",\"plotly_clickannotation\",\"plotly_doubleclick\",\"plotly_deselect\",\"plotly_afterplot\",\"plotly_sunburstclick\"],\"base_url\":\"https://plot.ly\"},\"evals\":[],\"jsHooks\":[]}</script>\n```\n\n:::\n:::\n\n\n\n## 5. Espacio operativo\n\nPara la toma de decisiones reales, el sistema FastPGT debe analizarse como una secuencia continua de corridas, potencialmente distribuidas a lo largo de múltiples flow cells.\n\nSe define el espacio:\n\n$$\nC = f(n, r)\n$$\n\ndonde:\n\n- $n$: número de muestras por corrida  \n- $r$: número total de corridas acumuladas  \n\n---\n\n### Estructura del sistema\n\nEl sistema presenta una organización modular:\n\n- cada 6 corridas consume una flow cell  \n- múltiples bloques implican múltiples flow cells  \n- el límite superior está definido por la capacidad del RBK (≈ 144 muestras)  \n\n$$\nFC = \\left\\lceil \\frac{r}{6} \\right\\rceil\n$$\n\n---\n\n### Interpretación operativa\n\nEl costo por muestra depende no solo del volumen, sino de cómo se distribuyen las corridas en el tiempo.\n\nPara cada número de corridas ($r$), se define una eficiencia relativa respecto al mejor escenario posible. Esto permite clasificar cada configuración en:\n\n- **Óptima** → costo mínimo alcanzable  \n- **Aceptable** → leve pérdida de eficiencia  \n- **Ineficiente** → fragmentación excesiva\n\nLas líneas discontinuas en $r = 6$ y $r = 12$ indican los puntos de transición entre flow cells.\n\nCada bloque de 6 corridas corresponde al uso completo de una flow cell. Al superar este límite, se requiere la apertura de una nueva flow cell, introduciendo un incremento discreto en el costo y modificando el régimen de amortización del sistema.\n\n\n::: {.cell}\n::: {.cell-output-display}\n![](appendix-costsRBKRAA_files/figure-html/unnamed-chunk-4-1.png){width=672}\n:::\n:::\n\n\nLas líneas discontinuas en $r = 6$ y $r = 12$ indican los puntos de transición entre flow cells.\n\nCada bloque de 6 corridas corresponde al uso completo de una flow cell. Al superar este límite, se requiere la apertura de una nueva flow cell, introduciendo un incremento discreto en el costo y modificando el régimen de amortización del sistema.\n\n\n::: callout-note\nLa optimización del sistema ocurre a nivel de trayectoria: cada decisión de corrida impacta el costo final acumulado.\n:::\n\nA partir de este modelo, se desarrolla una calculadora dinámica que permite evaluar escenarios específicos de operación en tiempo real.\n\n\n\n\n",
